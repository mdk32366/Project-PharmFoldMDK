# ── PharmFoldMDK local dev environment ────────────────────────────────────
# Copy this to `.env` (which is already gitignored — .gitignore) and fill in the
# real values. The `.env` file is LOCAL ONLY and must NEVER be committed. The same
# secrets also live as Fly secrets (`fly secrets set …`); these are the local copies
# that the worker, the enqueue CLI, and dev-up.ps1 read.
#
#   Copy-Item .env.example .env      # then edit .env with the real values below
#
# scripts/dev-up.ps1 loads this, opens the DB proxy, verifies it, and starts the
# worker — one command instead of ~15 by hand.
# ---------------------------------------------------------------------------

# The shared bearer token the worker presents to the Fly transport (D-031 §4).
# MUST be byte-for-byte identical to the WORKER_AUTH_TOKEN Fly secret, or the
# worker's claims are rejected 401. (Tonight's bug: the DB password was pasted here
# by mistake — dev-up.ps1 now verifies the token against the live transport before
# starting the worker, so that failure is caught, not folded silently.)
WORKER_AUTH_TOKEN=PUT_THE_REAL_64_HEX_TOKEN_HERE

# The database URL, PINNED to the fixed proxy port 16380. `fly mpg proxy` takes
# `--local-port` and defaults to 16380, so the port is stable, not random — which is
# exactly what lets this line be fully static with nothing to probe or prompt for.
# The +psycopg scheme is required: a bare postgresql:// resolves to psycopg2, which
# is NOT installed (the project pins psycopg 3). Fill in the real password only.
DATABASE_URL=postgresql+psycopg://fly-user:PUT_THE_REAL_DB_PASSWORD_HERE@localhost:16380/pharmfoldmdk

# The deployed transport base URL. The worker already defaults to this; here for
# completeness / overriding.
TRANSPORT_URL=https://pharmfoldmdk.fly.dev

# The MPG cluster id, used by dev-up.ps1 to open the proxy. Not a secret (an
# identifier; useless without Fly auth), so it is a real value, not a placeholder.
MPG_CLUSTER=gjpkdonnmkeoyln4
